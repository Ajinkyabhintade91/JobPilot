############################################################
# JobPilot configuration — single source of truth.
# Copy to .env, then run scripts/generate-keys.ps1 to fill
# every secret marked <generated>. Fill <manual> values yourself.
############################################################

########## Identity ##########
# Fixed single-user UUID. Every table defaults user_id to this; the dashboard
# auth user is seeded with the same id so RLS (auth.uid()) matches.
JOBPILOT_USER_ID=<generated>
# JobPilot dashboard login (GoTrue email/password user, created by scripts/seed-auth-user.ps1)
JOBPILOT_LOGIN_EMAIL=<manual>   # your email — becomes the dashboard login
JOBPILOT_LOGIN_PASSWORD=<generated>
# Crawler user-agent sent to ATS APIs. Adding a contact address is polite:
# USER_AGENT=JobPilot/0.1 (personal job search; contact: you@example.com)
USER_AGENT=

########## Supabase core ##########
POSTGRES_PASSWORD=<generated>
JWT_SECRET=<generated>
# HS256 JWTs signed with JWT_SECRET (role=anon / role=service_role), 10-year expiry
ANON_KEY=<generated>
SERVICE_ROLE_KEY=<generated>
# Optional new-style opaque keys — unused, leave empty
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Supabase Studio basic-auth (Studio is served through Kong at :8000)
DASHBOARD_USERNAME=jobpilot
DASHBOARD_PASSWORD=<generated>

SECRET_KEY_BASE=<generated>
REALTIME_DB_ENC_KEY=<generated>
PG_META_CRYPTO_KEY=<generated>
S3_PROTOCOL_ACCESS_KEY_ID=<generated>
S3_PROTOCOL_ACCESS_KEY_SECRET=<generated>

########## Supabase URLs / networking ##########
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:5173
ADDITIONAL_REDIRECT_URLS=
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

########## Supabase database ##########
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

########## Supabase auth (GoTrue) ##########
JWT_EXPIRY=3600
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
# SMTP is a stub — single admin-seeded user, no real mail is ever sent
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=stub-mail
SMTP_PORT=2500
SMTP_USER=stub
SMTP_PASS=stub
SMTP_SENDER_NAME=JobPilot
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

########## Supabase studio / rest / storage ##########
STUDIO_DEFAULT_ORGANIZATION=JobPilot
STUDIO_DEFAULT_PROJECT=JobPilot
OPENAI_API_KEY=
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub

########## Alerts & operations ##########
TELEGRAM_BOT_TOKEN=<manual — from @BotFather>
TELEGRAM_CHAT_ID=<manual — via getUpdates after messaging the bot>
# healthchecks.io ping URL for the nightly pipeline dead-man switch
HC_PING_URL=<manual — e.g. https://hc-ping.com/xxxxxxxx-xxxx-...>

########## App services ##########
N8N_ENCRYPTION_KEY=<generated>
GENERIC_TIMEZONE=America/Toronto
LITELLM_MASTER_KEY=<generated>
EMBEDDING_DIM=1024
OLLAMA_KEEP_ALIVE=10m

########## Langfuse (v2) ##########
LANGFUSE_DB_PASSWORD=<generated>
LANGFUSE_SALT=<generated>
LANGFUSE_NEXTAUTH_SECRET=<generated>
# Created in the Langfuse UI (project settings) after first boot, then pasted here
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

########## LLM providers ##########
# Strong tier — leave empty until acquired; nothing in Phase 0/1 calls it
ANTHROPIC_API_KEY=
